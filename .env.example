# Gemini API Configuration
# Get your keys at https://aistudio.google.com/app/apikey

# Default key (used if no specific key is found)
GEMINI_API_KEY=your_default_api_key_here

# App-specific keys (optional)
GEMINI_API_KEY_MISSION=your_mission_ia_key_here
GEMINI_API_KEY_REVIEWER=your_prompt_prof_key_here
GEMINI_API_KEY_ARCHITECT=your_architecte_mj_key_here

# Model Configuration
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# App Configuration
APP_URL=http://localhost:5173
VITE_APP_URL=http://localhost:5173
